# indexspace/ui/.env.local is auto-generated — do not edit manually.
#
# Add or change NEXT_PUBLIC_* vars in indexspace/.env, then run:
#   bun sync-env
# or simply start the dev server (sync runs automatically):
#   bun dev
#
# For production (Vercel etc.), set NEXT_PUBLIC_* vars in the platform
# environment dashboard — this file is not used in CI/CD.

NEXT_PUBLIC_BACKEND_URL=http://localhost:8787
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
