# IndexSpace Backend Configuration
#
# MOCK_VAULT controls whether the backend runs against a real chain or
# generates synthetic data locally.
#
#   MOCK_VAULT=true   → Mock mode. No chain needed. Uses Anvil (chain 31337).
#                       Safe for UI development.
#
#   MOCK_VAULT=false  → Real mode. Connects to Base Sepolia (chain 84532).
#                       Requires a valid Base Sepolia RPC and curator key.
#
# ── Development (recommended) ──────────────────────────────────────────────
MOCK_VAULT=true

# ── Real mode (Base Sepolia testnet) ───────────────────────────────────────
# MOCK_VAULT=false
# RPC_URL=https://sepolia.base.org
# CURATOR_PRIVATE_KEY=0x...
