# To change backend configuration, edit indexspace/.env, then run:
#
#   bun sync-env
#
# FunctionSpace backend auth now prefers:
#
#   FS_API_URL=https://fs-engine-api-dev.onrender.com
#   FS_USERNAME=<optional ui username / label>
#   FS_ACCESS_TOKEN=<required for backend auth>
#
# See indexspace/.env.example for the full source-of-truth template.
