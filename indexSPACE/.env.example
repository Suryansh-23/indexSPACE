# =============================================================================
# IndexSpace Environment Configuration
# =============================================================================
# Copy to .env and fill in values. .env is gitignored — never commit it.
#
# Two modes:
#   MOCK_VAULT=true   Local dev. No chain. Synthetic data. Safe default.
#   MOCK_VAULT=false  Real mode. Connects to Base Sepolia. Needs RPC + keys.
# =============================================================================

# =============================================================================
# BACKEND
# =============================================================================

# --- Mode switch ---
# true  = mock vault (default, safe for UI work)
# false = real onchain (Base Sepolia)
MOCK_VAULT=true

# --- SQLite path (relative to indexspace/backend/) ---
# Defaults to data/indexspace.db if unset. Use :memory: for ephemeral.
DB_PATH=data/indexspace.db

# --- Server ---
PORT=8787
HOST=0.0.0.0

# --- Polling ---
POLL_INTERVAL_MS=10000
CONFIRMATIONS=3
REORG_BUFFER=20

# =============================================================================
# REAL MODE ONLY (MOCK_VAULT=false)
# =============================================================================

# --- Chain RPC ---
# Public Base Sepolia endpoint (rate-limited) or your Alchemy/Infura URL
RPC_URL=https://sepolia.base.org

# --- Curator wallet ---
# This wallet calls fulfillDeposit / fulfillRedeem on-chain.
# Must be the curator address set during contract deployment.
# Generate: cast wallet new
CURATOR_PRIVATE_KEY=0xYOUR_CURATOR_PRIVATE_KEY_HERE

# --- Foundry deployment ---
# Contracts/.env is auto-generated from this root file by bun sync-env.
# If you deploy from the same wallet as curator, these can be identical.
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_HERE
BASE_SEPOLIA_USDC=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# =============================================================================
# FUNCTIONSPACE SDK (optional — enables real FS position execution)
# =============================================================================

# Paste the FunctionSpace access token for the curator/service account here.
# This is the preferred backend auth path because the core SDK can use a token
# directly without going through the React auth layer.
# Set FS_ACCESS_TOKEN and optionally FS_USERNAME for logging/reference.
# Without valid FunctionSpace auth, curator falls back to simulated positions
# (subscribe/redeem still works end-to-end, but no real FS market positions are
# opened).
FS_API_URL=https://fs-engine-api-dev.onrender.com
FS_USERNAME=your-functionspace-ui-username
FS_ACCESS_TOKEN=your-functionspace-access-token

# --- Optional runtime logging ---
# When enabled, backend appends JSONL entries to RUN_LOG_PATH for durable
# debugging of indexer, curator, and FunctionSpace API activity.
RUN_LOG_ENABLED=false
RUN_LOG_PATH=run.log
FS_TRACE_ENABLED=false

# =============================================================================
# UI (Next.js)
# =============================================================================
# NEXT_PUBLIC_* vars here are automatically synced to indexspace/ui/.env.local
# by scripts/sync-env.mjs, which runs before every `bun dev` / `bun dev:real`.
# Do NOT manually edit indexspace/ui/.env.local — it is auto-generated.
# For production UI deployments (e.g. Vercel), set these vars in the platform
# dashboard instead.
# =============================================================================

NEXT_PUBLIC_BACKEND_URL=http://localhost:8787
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id
